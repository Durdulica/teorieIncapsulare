## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio cache/options
.vs/
.vscode/

# Auto-generated files
Generated Files/
*.g.cs
*.g.i.cs

# MSTest test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml

# BenchmarkDotNet
BenchmarkDotNet.Artifacts/

# .NET Core / .NET
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# StyleCop
StyleCopReport.xml

# Files built by Visual Studio
*.cache
*.log
*.tlog
*.tmp
*.temp

# C++ files
*.obj
*.pch
*.pdb
*.ilk
*.idb
*.ipch
*.aps
*.ncb
*.opendb
*.VC.db

# Resharper
_ReSharper*/
*.ReSharper
*.DotSettings.user

# Rider
.idea/

# NuGet
*.nupkg
*.snupkg
packages/
!packages/build/
*.nuget.props
*.nuget.targets

# Azure / publish outputs
PublishScripts/
*.azurePubxml
*.pubxml
*.publishproj

# IIS Express
/.vs/config/applicationhost.config

# SQL Server files
*.mdf
*.ldf

# Windows Store app files
AppPackages/
BundleArtifacts/

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# Backup & temp files
*.bak
*.backup
*.old

# Coverage results
*.coverage
*.coveragexml

# DotCover
*.dotCover

# NCrunch
_NCrunch_*
.*crunch*.local.xml

# Web deploy
*.deploy.cmd
*.deploy.ps1

# Docker
docker-compose.override.yml

# Node.js (if using frontend tooling)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env
.env.*

# JetBrains Rider / VSCode workspace
*.sln.iml